<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>
<BorderPane prefHeight="768.0" prefWidth="1024.0" fx:controller="hust.soict.hedspi.aims.screen.controller.CartScreenController"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <top>
        <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <MenuBar>
                <Menu mnemonicParsing="false" text="Options">
                    <Menu mnemonicParsing="false" text="update Store">
                        <MenuItem mnemonicParsing="false" text="add Book"/>
                        <MenuItem mnemonicParsing="false" text="add CD"/>
                        <MenuItem mnemonicParsing="false" text="add DVD"/>
                    </Menu>
                    <MenuItem mnemonicParsing="false" text="view Store"/>
                    <MenuItem mnemonicParsing="false" text="view Cart"/>
                </Menu>
            </MenuBar>
            <Label text="CART" textFill="#00ffff">
                <font>
                    <Font size="50.0"/>
                </font>
                <VBox.margin>
                    <Insets left="10.0"/>
                </VBox.margin>
            </Label>
        </VBox>
    </top>
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="10.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                <padding>
                    <Insets top="10.0" bottom="10.0"/>
                </padding>
                <Label text="Filter:"/>
                <TextField fx:id="tfFilter"/>
                <RadioButton fx:id="radioBtnFilterId" mnemonicParsing="false" onAction="#filterModeChanged"
                             selected="true" text="by ID">
                    <toggleGroup>
                        <ToggleGroup fx:id="filterCategory"/>
                    </toggleGroup>
                </RadioButton>
                <RadioButton fx:id="radioBtnFilterTitle" mnemonicParsing="false" onAction="#filterModeChanged"
                             text="by title" toggleGroup="$filterCategory"/>
            </HBox>
            <TableView fx:id="tblMedia" columnResizePolicy="CONSTRAINED_RESIZE_POLICY">
                <columns>
                    <TableColumn fx:id="colMediaTitle" prefWidth="75.0" text="title"/>
                    <TableColumn fx:id="colMediaCategory" prefWidth="75.0" text="category"/>
                    <TableColumn fx:id="colMediaCost" prefWidth="75.0" text="cost"/>
                </columns>
            </TableView>
            <ButtonBar prefHeight="40.0" prefWidth="200.0">
                <buttons>
                    <Button fx:id="btnPlay" mnemonicParsing="false" onAction="#btnPlayPressed" text="Play"/>
                    <Button fx:id="btnRemove" mnemonicParsing="false" onAction="#btnRemovePressed" text="Remove"/>
                </buttons>
            </ButtonBar>
        </VBox>
    </center>
    <right>
        <VBox alignment="TOP_CENTER" prefHeight="200.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="50.0"/>
            </padding>
            <HBox alignment="CENTER" spacing="10.0">
                <Label text="total:">
                    <font>
                        <Font size="24.0"/>
                    </font>
                </Label>
                <Label fx:id="lblTotalCost" text="0$" textFill="#00ffff">
                    <font>
                        <Font size="24.0"/>
                    </font>
                </Label>
            </HBox>
            <Button mnemonicParsing="false" onAction="#btnPlaceOrderPressed" style="-fx-background-color: red;"
                    text="place order" textFill="#ffffff">
                <font>
                    <Font size="24.0"/>
                </font>
            </Button>
        </VBox>
    </right>
</BorderPane>